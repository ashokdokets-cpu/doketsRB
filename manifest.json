{
  "manifest_version": 3,
  "name": "LinkedIn to ResumeAI Pro",
  "version": "2.0.0",
  "description": "Import your LinkedIn profile into ResumeAI Pro and build a professional resume instantly",
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://doketsrb.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Import to ResumeAI Pro",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}