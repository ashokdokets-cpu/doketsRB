{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/linkedin-callback",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/linkedin-exchange.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/verify-payment.js": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}